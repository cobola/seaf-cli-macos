#!/bin/bash
# seaf-cli 包装脚本
# 用于 Homebrew 安装后的启动

set -euo pipefail

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# 获取安装根目录（Homebrew 安装路径）
if [[ "$SCRIPT_DIR" == "/usr/local/bin" ]]; then
    # Intel Mac Homebrew
    ROOT_DIR="/usr/local"
elif [[ "$SCRIPT_DIR" == "/opt/homebrew/bin" ]]; then
    # Apple Silicon Homebrew
    ROOT_DIR="/opt/homebrew"
else
    # 其他情况，使用脚本目录的父目录
    ROOT_DIR="$(dirname "$SCRIPT_DIR")"
fi

# 设置环境变量
export DYLD_LIBRARY_PATH="$ROOT_DIR/lib:$DYLD_LIBRARY_PATH:-"
export PYTHONPATH="$ROOT_DIR/lib/python3.11/site-packages:$PYTHONPATH:-"
export PATH="$SCRIPT_DIR:$PATH"

# 执行 seaf-cli
exec "$ROOT_DIR/bin/seaf-cli" "$@"